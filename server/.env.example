DATABASE_PATH="./data/traveloop.db"
JWT_SECRET="replace-with-a-long-secret"
CLIENT_URL="http://localhost:5173"
PORT=4000

# ============================================
# Transport Providers - Bus (GTFS-Realtime)
# ============================================
# GTFS-Realtime Feed URL for bus data
# Example: https://feeds.operator.com/gtfs-realtime
# Leave empty if not using GTFS-Realtime
GTFS_REALTIME_FEED_URL=

# Authorization header for GTFS-Realtime (if required)
# Example: "Bearer token123" or "Basic base64credentials"
GTFS_REALTIME_AUTH_HEADER=

# ============================================
# Transport Providers - Flight (Aviationstack)
# ============================================
# Aviationstack API Key - Get from https://aviationstack.com/
# Required for flight status/schedule endpoints
# Free tier: 500 requests/month
AVIATIONSTACK_API_KEY=

# ============================================
# Transport Providers - Train (Placeholder)
# ============================================
# NOTE: Train provider is currently stubbed (no real integration)
# These are placeholders for future implementation

# TRAIN_PROVIDER_API_KEY=
# TRAIN_PROVIDER_BASE_URL=